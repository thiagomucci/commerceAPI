// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum role {
  USER
  ADMIN
}

model user {
  id    String     @id @default(uuid())
  name  String
  email String  @unique
  password String
  role role @default(USER)
  createTime DateTime @default(now())
}

model produtos {
  id String @id @default(uuid())
  name String
  tipo String
  detalhes String
}